HOST=0.0.0.0
PORT=8000
MCP_TRANSPORT=http

# CockroachDB SQL connection. Use a Kubernetes Secret for real credentials.
COCKROACH_DSN='{"valueFrom": {"secretKeyRef": {"name": "cockroachdb-secret", "key": "dsn"}}}'

# Kubernetes discovery for the CockroachDB workload.
ENABLE_KUBERNETES=true
K8S_NAMESPACE=team1
COCKROACH_LABEL_SELECTOR=app.kubernetes.io/name=cockroachdb

# Safety defaults. MCP_READ_ONLY blocks mutations even when approved=true.
MCP_READ_ONLY=true
REQUIRE_APPROVAL=true

