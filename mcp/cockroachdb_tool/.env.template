HOST=0.0.0.0
PORT=8000
MCP_TRANSPORT=http

# CockroachDB SQL connection. Use a Kubernetes Secret for real credentials.
COCKROACH_DSN=postgresql://root@cockroachdb.cockroachdb.svc.cluster.local:26257/defaultdb?sslmode=disable
BACKUP_DESTINATION=nodelocal://1/cockroachdb-tool

# Kubernetes discovery for the CockroachDB workload.
ENABLE_KUBERNETES=true
K8S_NAMESPACE=cockroachdb
COCKROACH_LABEL_SELECTOR=app.kubernetes.io/name=cockroachdb
GRPC_PORT=26357
HTTP_PORT=8080

# Safety defaults. Set MCP_READ_ONLY=true to block mutating tools.
MCP_READ_ONLY=false
